{
  "name": "claude-tree-vis",
  "version": "0.1.0",
  "description": "Visual CLI for managing Claude Code worktrees",
  "type": "module",
  "bin": {
    "claude-tree-vis": "dist/cli.js"
  },
  "main": "out/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/cli.js",
